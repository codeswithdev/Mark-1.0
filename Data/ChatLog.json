    {
        "role": "assistant",
        "content": "\u092c\u094d\u0930\u0939\u094d\u092e\u093e\u0902\u0921 \u090f\u0915 \u0935\u093f\u0936\u093e\u0932 \u0914\u0930 \u091c\u091f\u093f\u0932 \u092a\u094d\u0930\u0923\u093e\u0932\u0940 \u0939\u0948 \u091c\u093f\u0938\u092e\u0947\u0902 \u0905\u0930\u092c\u094b\u0902 \u0917\u0948\u0932\u0947\u0915\u094d\u0938\u093f\u092f\u093e\u0901, \u0924\u093e\u0930\u0947, \u0917\u094d\u0930\u0939, \u0914\u0930 \u0905\u0928\u094d\u092f \u0935\u0938\u094d\u0924\u0941\u090f\u0902 \u0939\u0948\u0902\u0964 \u092f\u0939 \u090f\u0915 \u0910\u0938\u093e \u0938\u094d\u0925\u093e\u0928 \u0939\u0948 \u091c\u0939\u093e\u0902 \u0938\u092e\u092f \u0914\u0930 \u0938\u094d\u0925\u093e\u0928 \u0915\u0940 \u0905\u0935\u0927\u093e\u0930\u0923\u093e\u090f\u0902 \u0939\u092e\u093e\u0930\u0940 \u0938\u092e\u091d \u0938\u0947 \u092a\u0930\u0947 \u0939\u0948\u0902\u0964\n\n\u092c\u094d\u0930\u0939\u094d\u092e\u093e\u0902\u0921 \u0915\u0940 \u0909\u0924\u094d\u092a\u0924\u094d\u0924\u093f \u0914\u0930 \u0935\u093f\u0915\u093e\u0938 \u0915\u0947 \u092c\u093e\u0930\u0947 \u092e\u0947\u0902 \u0935\u0948\u091c\u094d\u091e\u093e\u0928\u093f\u0915 \u0915\u0908 \u0938\u093f\u0926\u094d\u0927\u093e\u0902\u0924\u094b\u0902 \u0915\u093e \u092a\u094d\u0930\u0938\u094d\u0924\u093e\u0935 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902, \u0932\u0947\u0915\u093f\u0928 \u0938\u092c\u0938\u0947 \u0905\u0927\u093f\u0915 \u0938\u094d\u0935\u0940\u0915\u0943\u0924 \u0938\u093f\u0926\u094d\u0927\u093e\u0902\u0924 \u092c\u093f\u0917 \u092c\u0948\u0902\u0917 \u0938\u093f\u0926\u094d\u0927\u093e\u0902\u0924 \u0939\u0948\u0964 \u0907\u0938 \u0938\u093f\u0926\u094d\u0927\u093e\u0902\u0924 \u0915\u0947 \u0905\u0928\u0941\u0938\u093e\u0930, \u0932\u0917\u092d\u0917 13.8 \u0905\u0930\u092c \u0935\u0930\u094d\u0937 \u092a\u0942\u0930\u094d\u0935, \u092c\u094d\u0930\u0939\u094d\u092e\u093e\u0902\u0921 \u090f\u0915 \u0905\u0924\u094d\u092f\u0927\u093f\u0915 \u0918\u0928\u0947 \u0914\u0930 \u0917\u0930\u094d\u092e \u092c\u093f\u0902\u0926\u0941 \u0938\u0947 \u0936\u0941\u0930\u0942 \u0939\u0941\u0906, \u091c\u094b \u090f\u0915 \u0935\u093f\u0936\u093e\u0932 \u0935\u093f\u0938\u094d\u092b\u094b\u091f \u0915\u0947 \u0938\u093e\u0925 \u092b\u0948\u0932\u0928\u0947 \u0932\u0917\u093e\u0964\n\n\u092c\u094d\u0930\u0939\u094d\u092e\u093e\u0902\u0921 \u0915\u0940 \u0935\u093f\u0938\u094d\u0924\u093e\u0930 \u0915\u0947 \u0938\u093e\u0925, \u092f\u0939 \u0920\u0902\u0921\u093e \u0914\u0930 \u0918\u0928\u0924\u094d\u0935 \u0915\u092e \u0939\u094b\u0924\u093e \u0917\u092f\u093e, \u0914\u0930 \u092a\u0939\u0932\u0947 \u0924\u093e\u0930\u0947 \u0914\u0930 \u0917\u0948\u0932\u0947\u0915\u094d\u0938\u093f\u092f\u093e\u0901 \u092c\u0928\u0928\u0947 \u0932\u0917\u0940\u0902\u0964 \u0906\u091c, \u092c\u094d\u0930\u0939\u094d\u092e\u093e\u0902\u0921 \u092e\u0947\u0902 \u0905\u0930\u092c\u094b\u0902 \u0917\u0948\u0932\u0947\u0915\u094d\u0938\u093f\u092f\u093e\u0901 \u0939\u0948\u0902, \u092a\u094d\u0930\u0924\u094d\u092f\u0947\u0915 \u092e\u0947\u0902 \u0905\u0930\u092c\u094b\u0902 \u0924\u093e\u0930\u0947 \u0914\u0930 \u0917\u094d\u0930\u0939 \u0939\u0948\u0902\u0964\n\n\u092c\u094d\u0930\u0939\u094d\u092e\u093e\u0902\u0921 \u0915\u0947 \u092c\u093e\u0930\u0947 \u092e\u0947\u0902 \u090f\u0915 \u0914\u0930 \u0926\u093f\u0932\u091a\u0938\u094d\u092a \u092c\u093e\u0924 \u092f\u0939 \u0939\u0948 \u0915\u093f \u092f\u0939 \u0928\u093f\u0930\u0902\u0924\u0930 \u0935\u093f\u0938\u094d\u0924\u093e\u0930 \u0915\u0930 \u0930\u0939\u093e \u0939\u0948, \u0914\u0930 \u0907\u0938\u0915\u0940 \u0935\u093f\u0938\u094d\u0924\u093e\u0930 \u0915\u0940 \u0926\u0930 \u092c\u0922\u093c \u0930\u0939\u0940 \u0939\u0948\u0964 \u092f\u0939 \u0935\u093f\u0938\u094d\u0924\u093e\u0930 \u0915\u0940 \u0926\u0930 \u0915\u094b \u0938\u092e\u091d\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0935\u0948\u091c\u094d\u091e\u093e\u0928\u093f\u0915\u094b\u0902 \u0928\u0947 \u0921\u093e\u0930\u094d\u0915 \u092e\u0948\u091f\u0930 \u0914\u0930 \u09